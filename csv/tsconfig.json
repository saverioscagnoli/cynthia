{
  "compilerOptions": {
    "target": "ES2016",
    "module": "CommonJS",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": "src",
    "paths": {
      "@consts": ["lib/consts.ts"],
      "@types": ["types/index.ts"]
    },
    "types": ["node"]
  }
}
